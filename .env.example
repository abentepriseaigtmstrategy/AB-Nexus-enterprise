# ================================================
# McLarens Nexus Enterprise — Environment Config
# Copy this to .env and fill in your values
# NEVER commit .env to git
# ================================================

# Cloudflare
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id

# D1 Database ID (get after: wrangler d1 create mclarens-db)
DATABASE_ID=your_d1_database_id

# JWT & Auth Secrets (use long random strings)
JWT_SECRET=change-this-to-a-strong-random-secret-min-32-chars
MAGIC_LINK_SECRET=change-this-to-another-strong-secret

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key

# Google OAuth (from console.cloud.google.com)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# App URLs (update after first deployment)
APP_URL=https://mclarens-nexus.pages.dev
API_URL=https://mclarens-nexus-api.workers.dev
